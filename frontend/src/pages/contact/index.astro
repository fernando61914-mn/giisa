---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Hero from "../../components/Hero.astro";
import { brand } from "../../config/brand";
import { client } from "../../data/client";
import { getContacto } from "../../lib/api/contact";

let contacto;
try {
  contacto = await getContacto();
} catch {
  contacto = undefined;
}
---

<BaseLayout
  title={contacto?.seo?.tituloSeo ?? "Contacto"}
  description={contacto?.seo?.descripcionSeo ?? `Contáctanos — ${brand.name}`}
>
  <Header slot="header" />

  <main>
    {
      contacto?.hero ? (
        <Hero data={contacto.hero} />
      ) : (
        <div class="bg-dark py-16 text-center">
          <h1 class="font-heading text-h1 font-bold text-white">Contáctanos</h1>
          <p class="mt-3 text-white/70">Estamos listos para atenderte.</p>
        </div>
      )
    }

    <section class="py-section">
      <div
        class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14"
      >
        <!-- Formulario -->
        <div class="lg:col-span-3">
          {
            contacto?.encabezado ? (
              <div class="mb-8">
                {contacto.encabezado.textoSuperior && (
                  <span class="text-topper font-bold uppercase tracking-widest text-accent">
                    {contacto.encabezado.textoSuperior}
                  </span>
                )}
                <h2 class="mt-2 font-heading text-h2 font-bold text-text">
                  {contacto.encabezado.titulo}
                </h2>
                {contacto.encabezado.descripcion && (
                  <p class="mt-2 text-text-muted">
                    {contacto.encabezado.descripcion}
                  </p>
                )}
              </div>
            ) : (
              <div class="mb-8">
                <h2 class="font-heading text-h2 font-bold text-text">
                  Envíanos un mensaje
                </h2>
                <p class="mt-2 text-text-muted">
                  Completa el formulario y te responderemos en menos de 24
                  horas.
                </p>
              </div>
            )
          }

          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/contact/success"
            class="flex flex-col gap-5"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden" aria-hidden="true">
              <label
                >Deja esto vacío: <input
                  name="bot-field"
                  tabindex="-1"
                  autocomplete="off"
                /></label
              >
            </p>

            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text"
                >Nombre <span class="text-accent" aria-hidden="true">*</span
                ></span
              >
              <input
                type="text"
                name="name"
                required
                autocomplete="name"
                class="rounded-md border border-border bg-background px-4 py-2.5 text-text shadow-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </label>

            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text"
                >Correo electrónico <span class="text-accent" aria-hidden="true"
                  >*</span
                ></span
              >
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                class="rounded-md border border-border bg-background px-4 py-2.5 text-text shadow-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </label>

            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Teléfono</span>
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                class="rounded-md border border-border bg-background px-4 py-2.5 text-text shadow-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              />
            </label>

            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text"
                >Mensaje <span class="text-accent" aria-hidden="true">*</span
                ></span
              >
              <textarea
                name="message"
                required
                rows={5}
                class="resize-y rounded-md border border-border bg-background px-4 py-2.5 text-text shadow-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              ></textarea>
            </label>

            <button
              type="submit"
              class="inline-flex min-h-12 items-center justify-center rounded-md bg-primary px-8 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90"
            >
              Enviar mensaje
            </button>
          </form>
        </div>

        <!-- Info de contacto -->
        <aside class="lg:col-span-2">
          <h3 class="font-heading text-h3 font-bold text-text">
            Información de contacto
          </h3>

          <ul class="mt-6 space-y-5">
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 size-5 shrink-0 text-primary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              <a
                href={`tel:${client.phoneForTel}`}
                class="text-text hover:text-primary transition-colors"
              >
                {contacto?.telefono ?? client.phoneFormatted}
              </a>
            </li>

            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 size-5 shrink-0 text-primary"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              <a
                href={`mailto:${contacto?.correo ?? client.email}`}
                class="text-text hover:text-primary transition-colors"
              >
                {contacto?.correo ?? client.email}
              </a>
            </li>

            {
              (contacto?.direccion ?? client.address) && (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 size-5 shrink-0 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                  <span class="text-text">
                    {contacto?.direccion ?? client.address}
                  </span>
                </li>
              )
            }
          </ul>

          {
            contacto?.urlGoogleMaps && (
              <div class="mt-8 overflow-hidden rounded-xl border border-border">
                <iframe
                  src={contacto.urlGoogleMaps}
                  width="100%"
                  height="250"
                  style="border:0"
                  allowfullscreen
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Ubicación en Google Maps"
                />
              </div>
            )
          }
        </aside>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>
