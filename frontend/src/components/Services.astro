---
import type { EncabezadoSeccion, Boton } from '../lib/types/shared';
import type { Servicio } from '../lib/types/service';
import { strapiImageUrl } from '../lib/strapi';

interface Props {
  encabezado?: EncabezadoSeccion;
  servicios?: Servicio[];
  boton?: Boton;
}

const { encabezado, servicios = [], boton } = Astro.props;

const textoSuperior = encabezado?.textoSuperior ?? 'Lo que hacemos';
const titulo        = encabezado?.titulo        ?? 'Nuestros Servicios';
const descripcion   = encabezado?.descripcion   ?? 'Soluciones integrales en construcción, supervisión e infraestructura para proyectos de cualquier escala.';

const PLACEHOLDER_IMG = 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=600&q=70';
---

<section id="servicios" class="bg-surface py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">

    <!-- Encabezado -->
    <div data-reveal class="mx-auto mb-12 max-w-2xl text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{textoSuperior}</span>
      <h2 class="mt-2 font-heading text-h2 font-bold text-text">{titulo}</h2>
      {descripcion && <p class="mt-3 text-text-muted leading-relaxed">{descripcion}</p>}
    </div>

    <!-- Cards de servicios -->
    {servicios.length > 0 ? (
      <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {servicios.map((s) => {
          const imgSrc = s.imagenPrincipal ? strapiImageUrl(s.imagenPrincipal.url) : PLACEHOLDER_IMG;
          return (
            <li>
              <a
                href={`/services/${s.slug}`}
                class="group flex h-full flex-col overflow-hidden rounded-xl border border-border bg-background shadow-sm transition-shadow hover:shadow-md"
              >
                <div class="aspect-video overflow-hidden">
                  <img
                    src={imgSrc}
                    alt={s.imagenPrincipal?.alternativeText ?? s.nombre}
                    width={480}
                    height={270}
                    loading="lazy"
                    decoding="async"
                    class="size-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <h3 class="font-heading text-h3 font-semibold text-text">{s.nombre}</h3>
                  {s.descripcionCorta && (
                    <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{s.descripcionCorta}</p>
                  )}
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors group-hover:text-accent">
                    Ver más
                    <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <!-- Fallback estático -->
      <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {[
          { nombre: 'Construcción',   descripcion: 'Ejecución de obras civiles e industriales con altos estándares de calidad y seguridad.' },
          { nombre: 'Supervisión',    descripcion: 'Control y seguimiento técnico de proyectos para garantizar el cumplimiento de especificaciones.' },
          { nombre: 'Infraestructura',descripcion: 'Desarrollo de infraestructura vial, hidráulica y urbana para comunidades y sectores productivos.' },
        ].map((s) => (
          <li>
            <div class="flex h-full flex-col overflow-hidden rounded-xl border border-border bg-background shadow-sm">
              <div class="aspect-video overflow-hidden bg-surface">
                <img src={PLACEHOLDER_IMG} alt={s.nombre} width={480} height={270} loading="lazy" class="size-full object-cover opacity-60" />
              </div>
              <div class="flex flex-1 flex-col p-5">
                <h3 class="font-heading text-h3 font-semibold text-text">{s.nombre}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{s.descripcion}</p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    )}

    <!-- Botón ver todos -->
    {boton && (
      <div class="mt-10 text-center">
        <a
          href={boton.url}
          class="inline-flex min-h-11 items-center gap-2 rounded-md border-2 border-primary px-7 py-3 text-base font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg"
        >
          {boton.texto}
        </a>
      </div>
    )}
  </div>
</section>

