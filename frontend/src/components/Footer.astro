---
import { brand } from "../config/brand";
import { client } from "../data/client";

const year = new Date().getFullYear();

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/about" },
  { label: "Servicios", href: "/services" },
  { label: "Proyectos", href: "/projects" },
  { label: "Blog", href: "/blog" },
  { label: "Contacto", href: "/contact" },
];

const serviciosLinks = [
  { label: "Construcción", href: "/services" },
  { label: "Supervisión", href: "/services" },
  { label: "Infraestructura", href: "/services" },
];
---

<footer class="bg-dark text-white/70" transition:persist>
  <div class="mx-auto max-w-site px-4 py-14 sm:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Marca -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a
          href="/"
          class="font-heading text-xl font-bold uppercase tracking-wide text-white"
        >
          {brand.name}
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed">
          {brand.tagline}
        </p>

        <!-- Redes sociales -->
        <div class="mt-5 flex items-center gap-4">
          {
            client.facebook && (
              <a
                href={client.facebook}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="text-white/50 transition-colors hover:text-white"
              >
                <svg
                  class="size-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
                </svg>
              </a>
            )
          }
          {
            client.instagram && (
              <a
                href={client.instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="text-white/50 transition-colors hover:text-white"
              >
                <svg
                  class="size-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                </svg>
              </a>
            )
          }
          {
            client.linkedin && (
              <a
                href={client.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="text-white/50 transition-colors hover:text-white"
              >
                <svg
                  class="size-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <!-- Navegación -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">
          Navegación
        </h3>
        <ul class="mt-4 space-y-2">
          {
            navLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm transition-colors hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Servicios -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">
          Servicios
        </h3>
        <ul class="mt-4 space-y-2">
          {
            serviciosLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm transition-colors hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">
          Contacto
        </h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a
              href={`tel:${client.phoneForTel}`}
              class="transition-colors hover:text-white"
            >
              {client.phoneFormatted}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${client.email}`}
              class="transition-colors hover:text-white"
            >
              {client.email}
            </a>
          </li>
          <li class="text-white/50">{client.address}</li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="mt-12 border-t border-white/10 pt-6 flex flex-col items-center justify-between gap-4 text-sm sm:flex-row"
    >
      <p>&copy; {year} {brand.name}. Todos los derechos reservados.</p>
      <div class="flex gap-5">
        <a href="/privacy" class="transition-colors hover:text-white"
          >Aviso de privacidad</a
        >
        <a href="/terms" class="transition-colors hover:text-white"
          >Términos y condiciones</a
        >
      </div>
    </div>
  </div>
</footer>
