---
import { brand } from "../config/brand";
import { client } from "../data/client";

const nav = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/#nosotros" },
  { label: "Servicios", href: "/#servicios" },
  { label: "Proyectos", href: "/#proyectos" },

  { label: "Contacto", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm transition-shadow duration-300"
  transition:persist
>
  <div
    class="mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 transition-opacity hover:opacity-80"
      aria-label={brand.name}
    >
      <img
        src="/logo.png"
        alt={brand.name}
        height="44"
        width="auto"
        class="h-11 w-auto object-contain"
        onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
      />
      <span
        class="font-heading text-xl font-bold uppercase tracking-wide text-primary"
        style="display:none"
      >
        {brand.name}
      </span>
    </a>

    <!-- Desktop nav -->
    <nav
      class="hidden items-center gap-1 lg:flex"
      aria-label="Primary navigation"
    >
      {
        nav.map(({ label, href }) => {
          const isActive = href.startsWith("/#")
            ? false
            : href === "/"
              ? currentPath === "/"
              : currentPath === href || currentPath.startsWith(href + "/");
          return (
            <a
              href={href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "rounded-md px-3 py-2 text-sm font-medium transition-colors",
                isActive
                  ? "bg-primary/10 text-primary"
                  : "text-text-muted hover:text-text",
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <!-- Desktop CTA + phone -->
    <div class="hidden items-center gap-4 lg:flex">
      <a
        href={`tel:${client.phoneForTel}`}
        class="text-sm font-semibold text-text hover:text-primary transition-colors"
      >
        {client.phoneFormatted}
      </a>
      <a
        href="/contact"
        class="inline-flex min-h-11 items-center rounded-md bg-accent px-5 py-2.5 text-sm font-bold text-dark shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        Cotiza tu proyecto
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-md text-text-muted hover:bg-surface lg:hidden"
    >
      <span class="sr-only">Toggle menu</span>
      <svg
        id="menu-icon-open"
        class="size-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="menu-icon-close"
        class="hidden size-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-background px-4 pb-6 pt-2 lg:hidden"
  >
    <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
      {
        nav.map(({ label, href }) => {
          const isActive = href.startsWith("/#")
            ? false
            : href === "/"
              ? currentPath === "/"
              : currentPath === href || currentPath.startsWith(href + "/");
          return (
            <a
              href={href}
              class:list={[
                "rounded-md px-3 py-3 text-base font-medium transition-colors",
                isActive
                  ? "bg-primary/10 text-primary"
                  : "text-text-muted hover:text-text hover:bg-surface",
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <div class="mt-4 flex flex-col gap-3 border-t border-border pt-4">
      <a
        href={`tel:${client.phoneForTel}`}
        class="flex items-center gap-2 px-3 py-2 text-base font-semibold text-text"
      >
        <svg
          class="size-5 text-primary"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          ></path>
        </svg>
        {client.phoneFormatted}
      </a>
      <a
        href="/contact"
        class="flex min-h-11 items-center justify-center rounded-md bg-accent px-5 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
      >
        Cotiza tu proyecto
      </a>
    </div>
  </div>
</header>

<script>
  function initHeaderMenu(): void {
    const header = document.querySelector<HTMLElement>("header");
    const btn = document.querySelector<HTMLButtonElement>("#menu-toggle");
    const menu = document.querySelector<HTMLElement>("#mobile-menu");
    const iconOpen = document.querySelector<HTMLElement>("#menu-icon-open");
    const iconClose = document.querySelector<HTMLElement>("#menu-icon-close");

    if (!header || !btn || !menu || !iconOpen || !iconClose) return;

    // header tiene transition:persist → solo inicializar listeners una vez
    if (header.dataset.menuInit === "true") return;
    header.dataset.menuInit = "true";

    const ACTIVE = ["bg-primary/10", "text-primary"] as const;
    const INACTIVE_D = ["text-text-muted", "hover:text-text"] as const;
    const INACTIVE_M = [
      "text-text-muted",
      "hover:text-text",
      "hover:bg-surface",
    ] as const;

    const isDesktop = () => window.matchMedia("(min-width: 1024px)").matches;

    function checkActive(href: string): boolean {
      const path = window.location.pathname;
      if (href.startsWith("/#")) return false;
      if (href === "/") return path === "/";
      return href === path || path.startsWith(href + "/");
    }

    function syncActiveLinks(): void {
      header!
        .querySelectorAll<HTMLAnchorElement>(
          'nav[aria-label="Primary navigation"] a',
        )
        .forEach((link) => {
          const active = checkActive(link.getAttribute("href") ?? "");
          link.classList.toggle(ACTIVE[0], active);
          link.classList.toggle(ACTIVE[1], active);
          link.classList.toggle(INACTIVE_D[0], !active);
          link.classList.toggle(INACTIVE_D[1], !active);
          active
            ? link.setAttribute("aria-current", "page")
            : link.removeAttribute("aria-current");
        });

      header!
        .querySelectorAll<HTMLAnchorElement>("#mobile-menu nav a")
        .forEach((link) => {
          const active = checkActive(link.getAttribute("href") ?? "");
          link.classList.toggle(ACTIVE[0], active);
          link.classList.toggle(ACTIVE[1], active);
          link.classList.toggle(INACTIVE_M[0], !active);
          link.classList.toggle(INACTIVE_M[1], !active);
          link.classList.toggle(INACTIVE_M[2], !active);
          active
            ? link.setAttribute("aria-current", "page")
            : link.removeAttribute("aria-current");
        });
    }

    function setMenuOpen(open: boolean): void {
      if (isDesktop()) open = false;
      btn!.setAttribute("aria-expanded", String(open));
      menu!.classList.toggle("hidden", !open);
      iconOpen!.classList.toggle("hidden", open);
      iconClose!.classList.toggle("hidden", !open);
    }

    // ── Listeners ────────────────────────────────────────────────────────
    btn.addEventListener("click", () => {
      if (isDesktop()) return;
      setMenuOpen(btn!.getAttribute("aria-expanded") !== "true");
    });

    menu.addEventListener("click", (e) => {
      if ((e.target as Element).closest("a[href]")) setMenuOpen(false);
    });

    document.addEventListener("astro:before-preparation", () =>
      setMenuOpen(false),
    );
    document.addEventListener("astro:after-swap", () => {
      setMenuOpen(false);
      syncActiveLinks();
    });

    window.addEventListener("resize", () => setMenuOpen(false));

    // Scroll shadow
    const updateShadow = () =>
      header!.classList.toggle("shadow-md", window.scrollY > 20);
    window.addEventListener("scroll", updateShadow, { passive: true });
    updateShadow();

    // Estado inicial
    setMenuOpen(false);
    syncActiveLinks();
  }

  // astro:page-load dispara en la primera carga Y en cada transición de página
  document.addEventListener("astro:page-load", initHeaderMenu);
</script>
