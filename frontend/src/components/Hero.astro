---
import { brand } from "../config/brand";

const PLACEHOLDER =
  "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1200&q=80";

interface Props {
  topper?: string;
  heading?: string;
  description?: string;

  ctaLabel?: string;
  ctaHref?: string;

  secondaryLabel?: string;
  secondaryHref?: string;

  imageSrc?: string;
  imageAlt?: string;

  phone?: string;
  phoneLabel?: string;
}

const {
  topper = "Licensed & Insured",

  heading = brand.tagline,
  description = brand.description,

  ctaLabel = "Get a Free Quote",
  ctaHref = "/contact",

  secondaryLabel = "Our Services",
  secondaryHref = "/services",

  imageSrc = PLACEHOLDER,
  imageAlt = "Professional tradesperson at work",

  phone,
  phoneLabel = "Call us",
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-background py-12 sm:py-16 md:py-20 lg:py-24"
>
  <div
    class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-12"
  >
    <div class="order-2 space-y-5 lg:order-1 lg:space-y-6">
      {
        topper && (
          <span class="inline-block rounded-full bg-accent/10 px-4 py-1.5 text-topper font-bold uppercase tracking-widest text-accent">
            {topper}
          </span>
        )
      }

      <h1
        class="font-heading text-display font-bold uppercase leading-none tracking-tight text-text"
        transition:name="hero-heading"
      >
        {heading}
      </h1>

      <p class="max-w-lg text-lead text-text-muted leading-relaxed">
        {description}
      </p>

      <div
        class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:gap-4"
      >
        <a
          href={ctaHref}
          class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
        >
          {ctaLabel}
        </a>

        <a
          href={secondaryHref}
          class="inline-flex min-h-[44px] items-center justify-center rounded-md border-2 border-primary px-6 py-3 text-base font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg"
        >
          {secondaryLabel}
        </a>
      </div>

      {
        phone && (
          <a
            href={`tel:${phone}`}
            class="inline-flex items-center gap-2 pt-1 text-sm font-semibold text-text-muted hover:text-primary"
          >
            {phoneLabel}
          </a>
        )
      }
    </div>

    <div
      class="relative order-1 overflow-hidden rounded-lg shadow-xl aspect-4/3 lg:order-2"
      transition:name="hero-image"
    >
      <img
        src={imageSrc || PLACEHOLDER}
        alt={imageAlt}
        class="size-full object-cover"
        loading="eager"
      />
    </div>
  </div>
</section>
