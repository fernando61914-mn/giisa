---
import { Image } from "astro:assets";
import type { ComponenteHero } from "../lib/types/shared";
import { strapiImageUrl } from "../lib/strapi";
import { brand } from "../config/brand";

const PLACEHOLDER =
  "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1400&q=80";

interface Props {
  data?: ComponenteHero;
}

const { data } = Astro.props;

const textoSuperior = data?.textoSuperior ?? "Infraestructura de calidad";
const titulo =
  data?.titulo ?? "Construimos infraestructura que transforma comunidades";
const subtitulo =
  data?.subtitulo ??
  "Más de 15 años de experiencia en construcción, supervisión e infraestructura con los más altos estándares de calidad y seguridad.";
const botonPrincipal = data?.botonPrincipal ?? {
  texto: "Cotiza tu proyecto",
  url: "/contact",
};
const botonSecundario = data?.botonSecundario ?? {
  texto: "Conoce nuestros servicios",
  url: "/services",
};
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden">
  <!-- Imagen de fondo: usa <Image> de Astro si viene de Strapi (optimiza a WebP en build),
       o <img> normal para el placeholder de Unsplash en desarrollo -->
  {
    data?.imagenFondo ? (
      <Image
        src={strapiImageUrl(data.imagenFondo.url)}
        alt={data.imagenFondo.alternativeText ?? brand.name}
        width={data.imagenFondo.width ?? 1400}
        height={data.imagenFondo.height ?? 900}
        class="absolute inset-0 size-full object-cover"
        loading="eager"
        transition:name="hero-image"
      />
    ) : (
      <img
        src={PLACEHOLDER}
        alt={brand.name}
        class="absolute inset-0 size-full object-cover"
        loading="eager"
        transition:name="hero-image"
      />
    )
  }

  <!-- Overlay degradado -->
  <div
    class="absolute inset-0 bg-linear-to-r from-dark/90 via-dark/70 to-dark/30"
  >
  </div>

  <!-- Contenido -->
  <div class="relative mx-auto max-w-site w-full px-4 py-20 sm:px-6 sm:py-28">
    <div class="max-w-2xl space-y-6">
      <!-- Badge superior -->
      {
        textoSuperior && (
          <span
            data-hero-item
            class="inline-block rounded-full bg-accent/20 border border-accent/40 px-4 py-1.5 text-topper font-bold uppercase tracking-widest text-accent"
          >
            {textoSuperior}
          </span>
        )
      }

      <!-- Título -->
      <h1
        data-hero-item
        class="font-heading text-display font-bold leading-tight text-white"
        transition:name="hero-heading"
      >
        {titulo}
      </h1>

      <!-- Subtítulo -->
      {
        subtitulo && (
          <p
            data-hero-item
            class="text-lead text-white/80 leading-relaxed max-w-xl"
          >
            {subtitulo}
          </p>
        )
      }

      <!-- Botones -->
      <div
        data-hero-item
        class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:gap-4"
      >
        <a
          href={botonPrincipal.url}
          class="inline-flex min-h-12 items-center justify-center rounded-md bg-accent px-7 py-3 text-base font-bold text-dark shadow-md transition-opacity hover:opacity-90"
        >
          {botonPrincipal.texto}
        </a>

        <a
          href={botonSecundario.url}
          class="inline-flex min-h-12 items-center justify-center rounded-md border-2 border-white/50 px-7 py-3 text-base font-bold text-white transition-colors hover:border-white hover:bg-white/10"
        >
          {botonSecundario.texto}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { initHeroAnimation } from "../lib/animations/hero";
  document.addEventListener("astro:page-load", initHeroAnimation);
</script>
