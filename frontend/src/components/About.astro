---
import type { Nosotros } from "../lib/types/shared";
import { strapiImageUrl } from "../lib/strapi";

const PLACEHOLDER =
  "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=900&q=80";

interface Props {
  data?: Nosotros;
}

const { data } = Astro.props;

const textoSuperior = data?.encabezado?.textoSuperior ?? "Sobre Nosotros";
const titulo =
  data?.encabezado?.titulo ?? "Más de 15 años construyendo confianza";
const descripcion =
  data?.encabezado?.descripcion ??
  "Somos una empresa especializada en construcción, supervisión e infraestructura, ofreciendo soluciones integrales con altos estándares de calidad, seguridad y cumplimiento normativo.";
const imageSrc = data?.imagen ? strapiImageUrl(data.imagen.url) : PLACEHOLDER;
const imageAlt = data?.imagen?.alternativeText ?? "Equipo GIISA en obra";
const boton = data?.boton ?? { texto: "Conócenos más", url: "/about" };
---

<section id="nosotros" class="py-section">
  <div
    data-reveal
    class="mx-auto grid max-w-site grid-cols-1 items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16"
  >
    <!-- Imagen -->
    <div class="overflow-hidden rounded-xl shadow-lg aspect-4/3">
      <img
        src={imageSrc}
        alt={imageAlt}
        width={700}
        height={525}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
    </div>

    <!-- Contenido -->
    <div class="space-y-5">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">
        {textoSuperior}
      </span>
      <h2 class="font-heading text-h2 font-bold leading-tight text-text">
        {titulo}
      </h2>
      <p class="text-text-muted leading-relaxed">
        {descripcion}
      </p>
      <div class="pt-2">
        <a
          href={boton.url}
          target={boton.abrirEnNuevaPestana ? "_blank" : undefined}
          rel={boton.abrirEnNuevaPestana ? "noopener noreferrer" : undefined}
          class="inline-flex min-h-11 items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90"
        >
          {boton.texto}
          <svg
            class="size-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
