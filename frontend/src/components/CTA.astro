---
import type { ComponenteCTA } from "../lib/types/shared";
import Icon from "./Icon.astro";

interface Props {
  data?: ComponenteCTA;
}

const { data } = Astro.props;

const titulo = data?.titulo ?? "¿Tienes un proyecto en mente?";
const descripcion =
  data?.descripcion ??
  "Contáctanos hoy y recibe asesoría personalizada sin costo. Nuestro equipo está listo para ayudarte.";
const boton = data?.boton ?? { texto: "Cotiza tu proyecto", url: "/contact" };
const beneficios = data?.beneficios ?? [
  {
    icono: "reloj",
    titulo: "Respuesta rápida",
    descripcion: "Te contactamos en menos de 24 horas.",
  },
  {
    icono: "usuario",
    titulo: "Asesoría personalizada",
    descripcion: "Solución adaptada a tus necesidades.",
  },
  {
    icono: "paloma",
    titulo: "Sin compromiso",
    descripcion: "Cotización gratuita y sin obligación.",
  },
];
---

<section class="bg-dark py-16 sm:py-20">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div
      data-reveal
      class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2"
    >
      <!-- Texto + botón -->
      <div class="space-y-6">
        <h2 class="font-heading text-h2 font-bold leading-tight text-white">
          {titulo}
        </h2>
        {
          descripcion && (
            <p class="text-lg text-white/70 leading-relaxed">{descripcion}</p>
          )
        }
        <a
          href={boton.url}
          target={boton.abrirEnNuevaPestana ? "_blank" : undefined}
          rel={boton.abrirEnNuevaPestana ? "noopener noreferrer" : undefined}
          class="inline-flex min-h-12 items-center gap-2 rounded-md bg-accent px-8 py-3 text-base font-bold text-dark shadow-md transition-opacity hover:opacity-90"
        >
          {boton.texto}
          <svg
            class="size-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      <!-- Lista de beneficios -->
      <ul class="space-y-6" role="list">
        {
          beneficios.map(({ icono, titulo: tit, descripcion: desc }) => (
            <li class="flex items-start gap-4">
              <div class="flex size-11 shrink-0 items-center justify-center rounded-lg bg-accent/20 text-accent">
                <Icon name={icono} class="size-5" />
              </div>
              <div>
                <p class="font-heading font-bold text-white">{tit}</p>
                {desc && (
                  <p class="mt-1 text-sm text-white/60 leading-relaxed">
                    {desc}
                  </p>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
