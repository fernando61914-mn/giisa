---
import type { TrustBarItem } from "../lib/types/shared";
import Icon from "./Icon.astro";

interface Props {
  items?: TrustBarItem[];
}

const {
  items = [
    {
      icono: "escudo",
      titulo: "Calidad garantizada",
      descripcion: "Materiales y procesos con los más altos estándares.",
    },
    {
      icono: "seguridad",
      titulo: "Seguridad primero",
      descripcion: "Protocolos estrictos en cada etapa del proyecto.",
    },
    {
      icono: "sostenibilidad",
      titulo: "Sostenibilidad",
      descripcion: "Soluciones responsables con el medio ambiente.",
    },
    {
      icono: "objetivo",
      titulo: "Enfoque integral",
      descripcion: "Diseño, construcción y supervisión en un solo equipo.",
    },
  ],
} = Astro.props;
---

<section
  class="bg-background shadow-sm border-b border-border"
  aria-label="Propuestas de valor"
>
  <div class="mx-auto max-w-site px-4 py-10 sm:px-6 sm:py-12">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.map(({ icono, titulo, descripcion }) => (
          <div class="flex items-start gap-4 rounded-lg bg-surface p-5">
            <div class="flex size-11 shrink-0 items-center justify-center rounded-lg bg-accent/15 text-accent">
              <Icon name={icono} class="size-6" />
            </div>
            <div>
              <p class="font-heading font-bold text-text">{titulo}</p>
              {descripcion && (
                <p class="mt-1 text-sm text-text-muted leading-relaxed">
                  {descripcion}
                </p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
