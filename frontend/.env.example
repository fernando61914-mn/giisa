# ── Variables de entorno ─────────────────────────────────────────────────────
# Copia este archivo como .env (desarrollo) o configura las variables
# directamente en Cloudflare Pages → Settings → Environment Variables.

# URL base de tu Strapi (sin trailing slash)
# Desarrollo local:
PUBLIC_STRAPI_URL=http://localhost:1337

# Producción (Strapi Cloud):
# PUBLIC_STRAPI_URL=https://tu-proyecto.api.strapiapp.com
